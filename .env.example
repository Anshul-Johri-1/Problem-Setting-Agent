# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Credentials are read directly by the tool layer and never enter agent context.

POLYGON_API_KEY=
POLYGON_API_SECRET=
POLYGON_OWNER_HANDLE=            # e.g. Anshul_Johri — used to construct the final link
AI_TOOL=claude-code                         # claude-code | cursor | copilot | codex | windsurf

# Optional override (defaults to https://polygon.codeforces.com/api)
# POLYGON_API_BASE_URL=
